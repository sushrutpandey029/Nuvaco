<p>Dealer Images Uploaded 🎉</p>

<p>
  A dealer has uploaded/updated banner images successfully.
</p>

<table
  width="100%"
  cellpadding="8"
  cellspacing="0"
  style="border-collapse: collapse; font-family: Arial, sans-serif; border: 1px solid #ddd;"
>

  <tr>
    <th align="left" style="border: 1px solid #ddd; background-color: #f5f5f5;">
      Field
    </th>

    <th align="left" style="border: 1px solid #ddd; background-color: #f5f5f5;">
      Details
    </th>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Dealer ID</b></td>
    <td style="border: 1px solid #ddd;">{{dealerId}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Dealer Code</b></td>
    <td style="border: 1px solid #ddd;">{{dealerCode}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Shop Name</b></td>
    <td style="border: 1px solid #ddd;">{{shopName}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Dealer Person</b></td>
    <td style="border: 1px solid #ddd;">{{dealerPerson}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Mobile Number</b></td>
    <td style="border: 1px solid #ddd;">{{mobile}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>State</b></td>
    <td style="border: 1px solid #ddd;">{{state}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>District</b></td>
    <td style="border: 1px solid #ddd;">{{district}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Address</b></td>
    <td style="border: 1px solid #ddd;">{{address}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Pincode</b></td>
    <td style="border: 1px solid #ddd;">{{pincode}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Language</b></td>
    <td style="border: 1px solid #ddd;">{{language}}</td>
  </tr>

  <tr>
    <td style="border: 1px solid #ddd;"><b>Total Uploaded Images</b></td>
    <td style="border: 1px solid #ddd;">{{totalImages}}</td>
  </tr>

</table>

<br />

<p>
  Dealer images are now available for admin review.
</p>

<div style="margin-top:25px;">

  <a
    href="{{adminPanelUrl}}"
    style="
      background:#6c63c4;
      color:#ffffff;
      text-decoration:none;
      padding:12px 22px;
      border-radius:8px;
      font-weight:600;
      display:inline-block;
    "
  >
    Open Admin Panel
  </a>

</div>

<p style="margin-top:20px;">
  <strong>– Nuvoco System</strong>
</p>