{{> dealerheader dealer=dealer}}

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    padding: 20px;
  }

  #dealerVideo {
    width: 70%;
    max-height: 70vh;
    object-fit: contain;
    display: block;
    border-radius: 12px;
  }

  #processingMsg {
    color: #333;
    font-size: 1.2rem;
    text-align: center;
    background: rgba(255,255,255,0.7);
    padding: 20px 30px;
    border-radius: 12px;
    backdrop-filter: blur(6px);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(0,0,0,0.15);
    border-top-color: #7c6fc4;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 12px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .btn-row {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 24px;
    width: 70%;
  }

  .btn-action {
    border-radius: 50px;
    padding: 12px 0;
    width: 48%;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    border: none;
    color: #fff;
    background: #8b7fd4;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-action:hover {
    background: #7c6fc4;
    color: #fff;
  }
</style>

<div class="video-wrapper">

  <video id="dealerVideo" controls autoplay playsinline>
    {{#if videoPath}}
      <source src="{{videoPath}}" type="video/mp4">
    {{else}}
      <source src="/uploads/videos/default.mp4" type="video/mp4">
    {{/if}}
  </video>

  <div id="processingMsg" {{#if videoPath}}style="display:none"{{/if}}>
    <div class="spinner"></div>
    ⏳ Aapka personalized video ban raha hai...
  </div>

  <!-- Buttons -->
  <div class="btn-row" id="btnRow" {{#if videoPath}}style="display:flex"{{else}}style="display:none"{{/if}}>
    <a href="javascript:void(0)" onclick="replayVideo()" class="btn-action">Re-Listen</a>
    <a href="/upload-pic" class="btn-action">Next</a>
  </div>

</div>

<script>
  function replayVideo() {
    const video = document.getElementById('dealerVideo');
    video.currentTime = 0;
    video.play();
  }

{{#unless videoPath}}
  const poll = setInterval(async () => {
    try {
      const res = await fetch('/video-status');
      const data = await res.json();
      if (data.status === 'ready' && data.videoPath) {
        clearInterval(poll);
        document.getElementById('processingMsg').style.display = 'none';
        document.getElementById('btnRow').style.display = 'flex';
        const video = document.getElementById('dealerVideo');
        video.src = data.videoPath;
        video.load();
        video.play();
      }
    } catch(e) {
      console.error('Poll error:', e);
    }
  }, 3000);
{{/unless}}
</script>

{{> dealerfooter}}