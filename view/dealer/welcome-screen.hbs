



{{> dealerheader dealer=dealer}}

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #000;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    flex: 1;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px); /* header height minus karo */
  }

  #dealerVideo {
    width: 100%;
    height: 100%;
    max-height: calc(100vh - 60px);
    object-fit: contain; /* poora video visible rahega */
    display: block;
  }

  #processingMsg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-size: 1.2rem;
    text-align: center;
    background: rgba(0,0,0,0.6);
    padding: 20px 30px;
    border-radius: 12px;
    backdrop-filter: blur(6px);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255,255,255,0.2);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 12px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<div class="video-wrapper">

  <video id="dealerVideo" controls autoplay playsinline>
    {{#if videoPath}}
      <source src="{{videoPath}}" type="video/mp4">
    {{else}}
      <source src="/uploads/videos/default.mp4" type="video/mp4">
    {{/if}}
  </video>

  <div id="processingMsg" {{#if videoPath}}style="display:none"{{/if}}>
    <div class="spinner"></div>
     Aapka personalized video ban raha hai...
  </div>

</div>

<script>
{{#unless videoPath}}
const poll = setInterval(async () => {
  try {
    const res = await fetch('/video-status');
    const data = await res.json();
    if (data.status === 'ready' && data.videoPath) {
      clearInterval(poll);
      document.getElementById('processingMsg').style.display = 'none';
      const video = document.getElementById('dealerVideo');
      video.src = data.videoPath;
      video.load();
      video.play();
    }
  } catch(e) {
    console.error('Poll error:', e);
  }
}, 3000);
{{/unless}}
</script>

{{> dealerfooter}}
