{{> dealerheader dealer=dealer}}
    
    
    <main class="purple-main">
      <div class="pbubble pb1"></div><div class="pbubble pb2"></div>
      <div class="pbubble pb3"></div><div class="pbubble pb4"></div><div class="pbubble pb5"></div>
      <div style="position:relative;z-index:2;width:100%;max-width:460px;">

{{#if data}}
  <video id="regionVideo" width="100%" controls style="border-radius:12px;">
    <source src="/{{data.video}}" type="video/mp4">
    Your browser does not support video.
  </video>
{{else}}
  <p class="text-white text-center">No video available</p>
{{/if}}

<div class="d-flex justify-content-center mt-3">
  <a href="javascript:void(0)" onclick="replayVideo()" class="btn btn-login px-5 me-3">
    Re-Listen
  </a>

  <a href="/upload-pic" class="btn btn-login px-5">
    Next
  </a>
</div>


