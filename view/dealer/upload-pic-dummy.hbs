            <span id="preview-text-1">Uploaded Pic 1</span>
          </label>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="pic-radio-wrap">
          <label class="pic-box" id="preview-label-2">
            <img id="preview2" src="" alt="" style="display:none; width:100%; height:100%; object-fit:cover; border-radius:8px;" />
            <span id="preview-text-2">Uploaded Pic 2</span>
          </label>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="pic-radio-wrap">
          <label class="pic-box" id="preview-label-3">
            <img id="preview3" src="" alt="" style="display:none; width:100%; height:100%; object-fit:cover; border-radius:8px;" />
            <span id="preview-text-3">Uploaded Pic 3</span>
          </label>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="pic-radio-wrap">
          <label class="pic-box" id="preview-label-4">
            <img id="preview4" src="" alt="" style="display:none; width:100%; height:100%; object-fit:cover; border-radius:8px;" />
            <span id="preview-text-4">Uploaded Pic 4</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Upload Inputs Row -->
