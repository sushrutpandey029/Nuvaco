        <label class="upload-box w-100">
          <input type="file" accept="image/*" class="d-none pic-input" data-slot="1" />
          <span id="upload-label-1">Upload Pic 1</span>
        </label>
      </div>
      <div class="col-6 col-md-3">
        <label class="upload-box w-100">
          <input type="file" accept="image/*" class="d-none pic-input" data-slot="2" />
          <span id="upload-label-2">Upload Pic 2</span>
        </label>
      </div>
      <div class="col-6 col-md-3">
        <label class="upload-box w-100">
          <input type="file" accept="image/*" class="d-none pic-input" data-slot="3" />
          <span id="upload-label-3">Upload Pic 3</span>
        </label>
      </div>
      <div class="col-6 col-md-3">
        <label class="upload-box w-100">
