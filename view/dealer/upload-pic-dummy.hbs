        Process Image
      </a>
    </div>

  </div>
</main>

{{> dealerfooter}}

<script>
  // Tracks selected files per slot: { 1: File, 2: File, ... }
  const selectedFiles = {};

  function showAlert(type, message) {
    const el = document.getElementById("uploadAlert");
    el.className = `alert alert-${type} alert-dismissible fade show`;
    el.innerHTML = `${message} <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    el.style.setProperty("display", "block", "important");
  }

  function hideAlert() {
    document.getElementById("uploadAlert").style.setProperty("display", "none", "important");
  }

  // Preview image in the slot box
  function setPreview(slot, file) {
    const img = document.getElementById(`preview${slot}`);
    const text = document.getElementById(`preview-text-${slot}`);
    const label = document.getElementById(`upload-label-${slot}`);

    const reader = new FileReader();
    reader.onload = (e) => {
      img.src = e.target.result;
      img.style.display = "block";
      text.style.display = "none";
      label.textContent = file.name.length > 12 ? file.name.substring(0, 12) + "…" : file.name;
    };
    reader.readAsDataURL(file);
  }

  // Check if all 4 slots filled — enable Process button
  function checkAllSelected() {
    const allFilled = Object.keys(selectedFiles).length === 4;
    const processBtn = document.getElementById("processBtn");
    if (allFilled) {
      processBtn.style.opacity = "1";
      processBtn.style.pointerEvents = "auto";
    } else {
      processBtn.style.opacity = "0.5";
      processBtn.style.pointerEvents = "none";
    }
    return allFilled;
  }

  // Attach change listeners to all file inputs
  document.querySelectorAll(".pic-input").forEach((input) => {
    input.addEventListener("change", function () {
      const slot = parseInt(this.dataset.slot);
      const file = this.files[0];
      if (!file) return;

      selectedFiles[slot] = file;
      setPreview(slot, file);

      hideAlert();

      // Auto-upload when all 4 selected
      if (checkAllSelected()) {
        uploadImages();
      }
    });
  });

  async function uploadImages() {
    const language = document.getElementById("languageSelect").value;

    if (!language) {
      showAlert("warning", "Please select a language before uploading.");
      return;
    }

    const dealerId = "{{dealer.id}}"; // Handlebars injects dealer id

    const formData = new FormData();
    formData.append("dealer_id", dealerId);
    formData.append("language", language);

    // Append all 4 files under the key "images"
    for (let slot = 1; slot <= 4; slot++) {
      formData.append("images", selectedFiles[slot]);
    }

    // Disable process button while uploading
    const processBtn = document.getElementById("processBtn");
    processBtn.textContent = "Uploading…";
    processBtn.style.pointerEvents = "none";
    processBtn.style.opacity = "0.7";

    try {
      const res = await fetch("/upload-dealer-images", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (data.success) {
        showAlert("success", "Images uploaded successfully!");
        processBtn.textContent = "Process Image";
        processBtn.style.opacity = "1";
        processBtn.style.pointerEvents = "auto";
        // Redirect to final pic after short delay
        setTimeout(() => { window.location.href = "/final-pic"; }, 1000);
      } else {
        showAlert("danger", data.message || "Upload failed.");
        processBtn.textContent = "Process Image";
        processBtn.style.opacity = "1";
        processBtn.style.pointerEvents = "auto";
      }
    } catch (err) {
      showAlert("danger", "Something went wrong. Please try again.");
      processBtn.textContent = "Process Image";
      processBtn.style.opacity = "1";
      processBtn.style.pointerEvents = "auto";
    }
  }

  // Process Image button click (manual trigger if needed)
  document.getElementById("processBtn").addEventListener("click", function (e) {
    e.preventDefault();
    uploadImages();
  });
</script>






