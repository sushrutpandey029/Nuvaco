{{> dealerheader dealer=dealer}}

<main class="purple-main" style="align-items: flex-start; padding-top: 32px">
  <div class="pbubble pb1"></div>
  <div class="pbubble pb2"></div>
  <div class="pbubble pb3"></div>

  <div style="position: relative; z-index: 2; width: 100%">

    {{#if (eq imageStatus "processing")}}
      <div class="alert alert-warning text-center mb-4">
        Your images are under processing.
      </div>
    {{/if}}

    {{#if (eq imageStatus "approved")}}
      <div class="alert alert-success text-center mb-4">
        Your images are approved successfully.
      </div>
    {{/if}}

    {{#if (eq imageStatus "rejected")}}
      <div class="alert alert-danger text-center mb-4">
        Your uploaded images were rejected. Please upload again.
      </div>
    {{/if}}

    <!-- Inline alert for upload feedback -->
    <div id="uploadAlert" style="display:none;" class="mb-3"></div>

    <div class="row">

      <!-- LEFT SIDE — Photo preview -->
      <div class="col-md-6">
        <div class="row g-3">

          <!-- PIC 1 (only slot active) -->
          <div class="col-6">
            <div class="pic-radio-wrap">
              <label class="pic-box" id="preview-label-0">
                {{#if (gt images.length 0)}}
                  <img id="preview0"
                    src="{{images.[0].image}}"
                    alt=""
                    style="width:100%; height:220px; object-fit:cover; border-radius:8px;" />
                {{else}}
                  <img id="preview0"
                    src=""
                    alt=""
                    style="display:none; width:100%; height:220px; object-fit:cover; border-radius:8px;" />
                  <span id="preview-text-0">Uploaded Pic 1</span>
                {{/if}}
              </label>
            </div>
          </div>

        </div>
      </div>

      <!-- RIGHT SIDE — Template previews -->
      <div class="col-md-6">
        {{#each templates}}
          <div class="mb-3">
            <img
              src="{{this.image}}"
              alt="{{this.name}}"
              style="width:100%; border-radius:10px;"
            />
          </div>
        {{/each}}
      </div>

    </div>

    <!-- Upload Input Row -->
    <div class="row g-3 mt-3">

      <!-- Only 1 upload slot is active -->
      <div class="col-6 col-md-3">
        <label class="upload-box w-100" style="cursor:pointer;">
          <input type="file" accept="image/*" class="d-none pic-input"
            data-slot="0"
            data-existing-id="{{images.[0].id}}" />
          <span id="upload-label-0">
            {{#if (gt images.length 0)}}Change Pic 1{{else}}Upload Pic 1{{/if}}
          </span>
        </label>
      </div>

      <!-- Language Select -->
      <div class="col-12 col-md-12 justify-content-center">
        <select class="region-select mt-3" id="languageSelect">
          <option value="">Select Language of Cutout</option>
          <option value="HINDI"     {{#if (eq images.[0].language "HINDI")}}selected{{/if}}>HINDI</option>
          <option value="ENGLISH"   {{#if (eq images.[0].language "ENGLISH")}}selected{{/if}}>ENGLISH</option>
          <option value="ODIA"      {{#if (eq images.[0].language "ODIA")}}selected{{/if}}>ODIA</option>
          <option value="PUNJABI"   {{#if (eq images.[0].language "PUNJABI")}}selected{{/if}}>PUNJABI</option>
          <option value="BENGALI"   {{#if (eq images.[0].language "BENGALI")}}selected{{/if}}>BENGALI</option>
          <option value="GUJARATI"  {{#if (eq images.[0].language "GUJARATI")}}selected{{/if}}>GUJARATI</option>
          <option value="ASSAMESE"  {{#if (eq images.[0].language "ASSAMESE")}}selected{{/if}}>ASSAMESE</option>
        </select>
      </div>

    </div>

    <!-- Action Buttons -->
    <div class="text-center mt-4">
      <a href="/" class="btn btn-login px-5 me-3"
        style="border-radius: 50px; display: inline-block; text-decoration: none;">
        Re-Listen
      </a>

      <!--
        BUG FIX: Button was locked behind `images.length === 4`,
        but only 1 upload slot exists now.
        Fix: enable if at least 1 image already exists OR user has selected a new file.
        JS handles dynamic enable/disable; this just sets the initial server-rendered state.
      -->
      <a href="#" id="processBtn" class="btn btn-login px-5"
        style="border-radius: 50px; display: inline-block; text-decoration: none;
               {{#if (gt images.length 0)}}opacity:1; pointer-events:auto;{{else}}opacity:0.5; pointer-events:none;{{/if}}">
        Process Image
      </a>
    </div>

  </div>
</main>

{{> dealerfooter}}

<script>
  // How many images already exist in DB for this dealer
  const totalExisting = {{images.length}};

  // Tracks newly selected files: slot -> { file, existingId }
  const selectedFiles = {};

  function showAlert(type, message) {
    const el = document.getElementById("uploadAlert");
    el.className = `alert alert-${type} alert-dismissible fade show`;
    el.innerHTML = `${message} <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    el.style.setProperty("display", "block", "important");
  }

  function hideAlert() {
    document.getElementById("uploadAlert").style.setProperty("display", "none", "important");
  }

  function setPreview(slot, file) {
    const img  = document.getElementById(`preview${slot}`);
    const text = document.getElementById(`preview-text-${slot}`);
    const lbl  = document.getElementById(`upload-label-${slot}`);

    if (!img) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      img.src = e.target.result;
      img.style.display = "block";
      if (text) text.style.display = "none";
      if (lbl)  lbl.textContent = file.name.length > 12
        ? file.name.substring(0, 12) + "…"
        : file.name;
    };
    reader.readAsDataURL(file);
  }

  /**
   * BUG FIX: was checking (totalExisting + totalSelected) >= 4
   * Now: ready if at least 1 image exists OR 1 file is newly selected
   */
  function checkReady() {
    const processBtn   = document.getElementById("processBtn");
    const totalSelected = Object.keys(selectedFiles).length;
    const allReady = (totalExisting + totalSelected) >= 1;

    processBtn.style.opacity       = allReady ? "1"    : "0.5";
    processBtn.style.pointerEvents = allReady ? "auto" : "none";
  }

  document.querySelectorAll(".pic-input").forEach((input) => {
    input.addEventListener("change", function () {
      const slot       = parseInt(this.dataset.slot);
      const existingId = this.dataset.existingId || "";
      const file       = this.files[0];
      if (!file) return;

      selectedFiles[slot] = { file, existingId };
      setPreview(slot, file);
      hideAlert();
      checkReady();
    });
  });

  async function uploadImages() {
    const language = document.getElementById("languageSelect").value;

    if (!language) {
      showAlert("warning", "Please select a language before uploading.");
      return;
    }

    // All images already exist and nothing new was selected → go straight to final
    if (totalExisting >= 1 && Object.keys(selectedFiles).length === 0) {
      window.location.href = "/final-pic";
      return;
    }

    if (Object.keys(selectedFiles).length === 0) {
      showAlert("warning", "Please select an image to upload.");
      return;
    }

    const dealerId = "{{dealer.id}}";
    const formData = new FormData();
    formData.append("dealer_id", dealerId);
    formData.append("language", language);

    const slots    = Object.keys(selectedFiles).map(Number).sort((a, b) => a - b);
    const imageIds = slots.map((slot) => selectedFiles[slot].existingId || "");

    slots.forEach((slot) => {
      formData.append("images", selectedFiles[slot].file);
    });

    formData.append("image_ids", JSON.stringify(imageIds));

    const processBtn = document.getElementById("processBtn");
    processBtn.textContent          = "Uploading…";
    processBtn.style.pointerEvents  = "none";
    processBtn.style.opacity        = "0.7";

    try {
      const res  = await fetch("/upload-dealer-images", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (data.success) {
        showAlert("success", "Images saved successfully!");
        processBtn.textContent = "Process Image";
        processBtn.style.opacity = "1";
        processBtn.style.pointerEvents = "auto";
        setTimeout(() => { window.location.href = "/final-pic"; }, 1000);
      } else {
        showAlert("danger", data.message || "Upload failed.");
        processBtn.textContent = "Process Image";
        processBtn.style.opacity = "1";
        processBtn.style.pointerEvents = "auto";
      }
    } catch (err) {
      console.error("Upload error:", err);
      showAlert("danger", "Something went wrong. Please try again.");
      processBtn.textContent = "Process Image";
      processBtn.style.opacity = "1";
      processBtn.style.pointerEvents = "auto";
    }
  }

  document.getElementById("processBtn").addEventListener("click", function (e) {
    e.preventDefault();
    uploadImages();
  });
</script>
