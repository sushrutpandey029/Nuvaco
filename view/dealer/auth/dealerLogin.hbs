<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuvoco – Login</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="../assets/css/style.css" />
  </head>

  <body class="login-body">
    <div class="container-fluid h-100">
      <div class="row h-100">

        <!-- Left branding panel -->
        <div
          class="col-lg-6 login-left d-flex align-items-center justify-content-center"
        >
          <div class="bubble b1"></div>
          <div class="bubble b2"></div>
          <div class="bubble b3"></div>
          <div class="text-center">
            <div class="logo-ring">
              <div class="logo-text">
                <span class="nu">NU</span><span class="v-letter">V</span><span
                  class="oco"
                >OCO</span><sup class="reg">®</sup>
              </div>
              <div class="tagline">Shaping a new world</div>
            </div>
          </div>
        </div>

        <!-- Right login form -->
        <div
          class="col-lg-6 login-right d-flex align-items-center justify-content-center"
        >
          <div class="bubble br1"></div>
          <div class="bubble br2"></div>
          <div class="login-card">
            <h2 class="login-title">Log in</h2>
            <div class="title-underline"></div>

            <!-- ✅ Server-side flash (on page load after redirect) -->
            {{#if error}}
              <div
                class="alert alert-danger alert-dismissible fade show"
                role="alert"
              >
                {{error}}
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                ></button>
              </div>
            {{/if}}
            {{#if success}}
              <div
                class="alert alert-success alert-dismissible fade show"
                role="alert"
              >
                {{success}}
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                ></button>
              </div>
            {{/if}}

            <!-- ✅ JS inline alert (for verify OTP errors — no page reload) -->
            <div id="inlineAlert" style="display:none;"></div>

            <form id="otpForm">

              <!-- Mobile -->
              <div class="mb-4">
                <input
                  type="text"
                  id="contact"
                  maxlength="10"
                  class="form-control login-input"
                  placeholder="Enter Mobile Number"
                />
              </div>

              <!-- Send OTP Button -->
              <div class="d-grid mb-3" id="sendBtnWrap">
                <button type="button" class="btn btn-login" onclick="sendOTP()">
                  Send OTP
                </button>
              </div>

              <!-- OTP Field (hidden initially) -->
              <div class="mb-4" id="otpField" style="display:none;">
                <input
                  type="text"
                  id="otp"
                  maxlength="6"
                  class="form-control login-input"
                  placeholder="Enter 6-digit OTP"
                />
              </div>

              <!-- Verify + Change Number (hidden initially) -->
              <div id="otpActions" style="display:none;">
                <div class="d-grid mb-3">
                  <button
                    type="button"
                    class="btn btn-login"
                    onclick="verifyOTP()"
                  >
                    Verify OTP
                  </button>
                </div>
                <div class="text-center">
                  <a href="/login" onclick="changeNumber()">Change Number</a>
                </div>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>

    <script>
      // ✅ Show inline alert (for JS errors without page reload) function
      showInlineAlert(type, message) { const el =
      document.getElementById("inlineAlert"); el.className = `alert
      alert-${type} alert-dismissible fade show`; el.innerHTML = ` ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `; el.style.display = "block"; } function hideInlineAlert() { const el =
      document.getElementById("inlineAlert"); el.style.display = "none"; } async
      function sendOTP() { hideInlineAlert(); const contact =
      document.getElementById("contact").value.trim(); if (!contact ||
      contact.length !== 10 || !/^\d+$/.test(contact)) {
      showInlineAlert("danger", "Enter a valid 10-digit mobile number"); return;
      } const res = await fetch("/send-otp", { method: "POST", headers: {
      "Content-Type": "application/json" }, body: JSON.stringify({ contact }),
      }); const data = await res.json(); // ✅ Always JSON now — no redirect
      check needed if (data.success) {
      document.getElementById("contact").disabled = true;
      document.getElementById("sendBtnWrap").style.display = "none";
      document.getElementById("otpField").style.display = "block";
      document.getElementById("otpActions").style.display = "block";
      document.getElementById("otp").focus(); } else { showInlineAlert("danger",
      data.message); // ✅ Show error inline } }

      {{! async function sendOTP() {
        hideInlineAlert();

        const contact = document.getElementById("contact").value.trim();

        if (!contact || contact.length !== 10 || !/^\d+$/.test(contact)) {
          showInlineAlert("danger", "Enter a valid 10-digit mobile number");
          return;
        }

        const res = await fetch("/send-otp", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ contact }),
        });

        // ✅ Backend error — redirected to /login with flash
        if (res.redirected) {
          window.location.href = res.url;
          return;
        }

        const data = await res.json();

        if (data.success) {
          // ✅ Show OTP field + actions, lock contact
          document.getElementById("contact").disabled = true;
          document.getElementById("sendBtnWrap").style.display = "none";
          document.getElementById("otpField").style.display = "block";
          document.getElementById("otpActions").style.display = "block";
          document.getElementById("otp").focus();
        }
      } }}

      async function verifyOTP() { hideInlineAlert(); const contact =
      document.getElementById("contact").value.trim(); const otp =
      document.getElementById("otp").value.trim(); if (!otp || otp.length !== 6
      || !/^\d+$/.test(otp)) { showInlineAlert("danger", "Enter a valid 6-digit
      OTP"); return; } const res = await fetch("/verify-otp", { method: "POST",
      headers: { "Content-Type": "application/json" }, body: JSON.stringify({
      contact, otp }), }); const data = await res.json(); if (data.success) { //
      ✅ Redirect to home window.location.href = data.redirect; } else { // ✅
      Show error inline — OTP field stays visible showInlineAlert("danger",
      data.message); document.getElementById("otp").value = "";
      document.getElementById("otp").focus(); } } function changeNumber() {
      hideInlineAlert(); // ✅ Reset everything
      document.getElementById("contact").disabled = false;
      document.getElementById("contact").value = "";
      document.getElementById("otp").value = "";
      document.getElementById("sendBtnWrap").style.display = "block";
      document.getElementById("otpField").style.display = "none";
      document.getElementById("otpActions").style.display = "none";
      document.getElementById("contact").focus(); }
    </script>

  </body>
</html>