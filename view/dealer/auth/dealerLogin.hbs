            <form id="otpForm">

  <!-- Mobile -->
  <div class="mb-4">
    <input
      type="text"
      id="contact"
      maxlength="10"
      class="form-control login-input"
      placeholder="Enter Mobile Number"
    />
  </div>

  <!-- Send OTP -->
  <div class="d-grid mb-3">
    <button type="button" id="sendBtn" class="btn btn-login" onclick="sendOTP()">
      Send OTP
    </button>
  </div>

  <!-- Change Number -->
  <div class="mb-3 text-center" id="changeNumber" style="display:none;">
    <a href="#" onclick="changeNumber()">Change Number</a>
  </div>

  <!-- OTP -->
  <div class="mb-4" id="otpField" style="display:none;">
    <input
      type="text"
      id="otp"
      maxlength="6"
      class="form-control login-input"
      placeholder="Enter 6-digit OTP"
    />
  </div>

  <!-- Verify -->
  <div class="d-grid" id="verifyBtn" style="display:none;">
    <button type="button" class="btn btn-login" onclick="verifyOTP()">
      Verify OTP
    </button>
  </div>

</form>
          </div>
        </div>

      </div>
    </div>

    <script
   
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>

    <script>
async function sendOTP() {
  const contact = document.getElementById("contact").value;

  if (!contact || contact.length !== 10) {
    alert("Enter valid mobile number");
    return;
  }

  const res = await fetch("/send-otp", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ contact }),
  });

  const data = await res.json();

  if (data.success) {
    alert(data.message);

    // ✅ Disable input
    document.getElementById("contact").disabled = true;

    // ✅ Hide send button
    document.getElementById("sendBtn").style.display = "none";

    // ✅ Show change number
    document.getElementById("changeNumber").style.display = "block";

    // ✅ Show OTP + Verify
    document.getElementById("otpField").style.display = "block";
    document.getElementById("verifyBtn").style.display = "block";

  } else {
    alert(data.message);
  }
}

async function verifyOTP() {
  const contact = document.getElementById("contact").value;
  const otp = document.getElementById("otp").value;

  if (!otp || otp.length !== 6) {
    alert("Enter valid OTP");
    return;
  }

  const res = await fetch("/verify-otp", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ contact, otp }),
  });

  const data = await res.json();

  if (data.success) {
    window.location.href = "/";
  } else {
    alert(data.message);
  }
}

function changeNumber() {
  document.getElementById("contact").disabled = false;
  document.getElementById("contact").value = "";

  document.getElementById("otp").value = "";

  document.getElementById("sendBtn").style.display = "block";
  document.getElementById("changeNumber").style.display = "none";
  document.getElementById("otpField").style.display = "none";
  document.getElementById("verifyBtn").style.display = "none";
}
</script>

