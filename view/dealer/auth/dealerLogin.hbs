<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuvoco – Login</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="../assets/css/style.css" />
  </head>

  <body class="login-body">
    <div class="container-fluid h-100">
      <div class="row h-100">

        <!-- Left branding panel -->
        <div
          class="col-lg-6 login-left d-flex align-items-center justify-content-center"
        >
          <div class="bubble b1"></div>
          <div class="bubble b2"></div>
          <div class="bubble b3"></div>
          <div class="text-center">
            <div class="logo-ring">
              <div class="logo-text">
                <span class="nu">NU</span><span class="v-letter">V</span><span
                  class="oco"
                >OCO</span><sup class="reg">®</sup>
              </div>
              <div class="tagline">Shaping a new world</div>
            </div>
          </div>
        </div>


        <!-- Right login form -->
        <div class="col-lg-6 login-right d-flex align-items-center justify-content-center">

          <div class="bubble br1"></div>
          <div class="bubble br2"></div>
          <div class="login-card">
            <h2 class="login-title">Log in</h2>
            <div class="title-underline"></div>

            <!-- ✅ Server-side flash (on page load after redirect) -->
            {{#if error}}
              <div
                class="alert alert-danger alert-dismissible fade show"
                role="alert"
              >
                {{error}}
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                ></button>
              </div>
            {{/if}}
            {{#if success}}
              <div
                class="alert alert-success alert-dismissible fade show"
                role="alert"
              >
                {{success}}
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                ></button>
              </div>
            {{/if}}

            <!-- ✅ JS inline alert (for verify OTP errors — no page reload) -->
            <div id="inlineAlert" style="display:none;"></div>

            <form id="otpForm">

              <!-- Mobile -->
              <div class="mb-4" id="contactWrap">
                <input
                  type="text"
                  id="contact"
                  maxlength="10"
                  class="form-control login-input"
                  placeholder="Enter Mobile Number"
                />
              </div>

              <!-- Send OTP Button -->
              <div class="d-grid mb-3" id="sendBtnWrap">
                <button type="button" class="btn btn-login" onclick="sendOTP()">
                  Send OTP
                </button>
              </div>

              <!-- OTP Field (hidden initially) -->
              <div class="mb-4" id="otpField" style="display:none;">
                <input
                  type="text"
                  id="otp"
                  maxlength="6"
                  class="form-control login-input"
                  placeholder="Enter 6-digit OTP"
                />
              </div>

              <!-- Verify + Change Number (hidden initially) -->
              <div id="otpActions" style="display:none;">
                <div class="d-grid mb-3">
                  <button
                    type="button"
                    class="btn btn-login"
                    onclick="verifyOTP()"
                  >
                    Verify OTP
                  </button>
                </div>
               
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>

   <script>
  function showInlineAlert(type, message) {
    const el = document.getElementById("inlineAlert");
    el.className = `alert alert-${type} alert-dismissible fade show`;
    el.innerHTML = `
      ${message}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    el.style.display = "block";
  }

  function hideInlineAlert() {
    const el = document.getElementById("inlineAlert");
    el.style.display = "none";
  }

  async function sendOTP() {
    hideInlineAlert();

    const contact = document.getElementById("contact").value.trim();

    if (!contact || contact.length !== 10 || !/^\d+$/.test(contact)) {
      showInlineAlert("danger", "Enter a valid 10-digit mobile number");
      return;
    }

    // Show sending state — disable button and input
    const sendBtn = document.querySelector("#sendBtnWrap .btn-login");
    sendBtn.disabled = true;
    sendBtn.textContent = "Sending…";
    document.getElementById("contact").disabled = true;

    try {
      const res = await fetch("/send-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contact }),
      });

      const data = await res.json();

      if (data.success) {
        // Hide number field and send OTP button entirely
        
document.getElementById("contactWrap").style.setProperty("display", "none", "important");
document.getElementById("sendBtnWrap").style.setProperty("display", "none", "important");

       
        // Show OTP entry
        document.getElementById("otpField").style.display = "block";
        document.getElementById("otpActions").style.display = "block";
        document.getElementById("otp").focus();
      } else {
        // Restore fields so user can retry
        sendBtn.disabled = false;
        sendBtn.textContent = "Send OTP";
        document.getElementById("contact").disabled = false;
        showInlineAlert("danger", data.message);
      }
    } catch (err) {
      // Restore fields on network error
      sendBtn.disabled = false;
      sendBtn.textContent = "Send OTP";
      document.getElementById("contact").disabled = false;
      showInlineAlert("danger", "Something went wrong. Please try again.");
    }
  }

  async function verifyOTP() {
    hideInlineAlert();

    const contact = document.getElementById("contact").value.trim();
    const otp = document.getElementById("otp").value.trim();

    if (!otp || otp.length !== 6 || !/^\d+$/.test(otp)) {
      showInlineAlert("danger", "Enter a valid 6-digit OTP");
      return;
    }

    const res = await fetch("/verify-otp", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ contact, otp }),
    });

    const data = await res.json();

    if (data.success) {
      window.location.href = data.redirect;
    } else {
      showInlineAlert("danger", data.message);
      document.getElementById("otp").value = "";
      document.getElementById("otp").focus();
    }
  }

 
</script>

  </body>
</html>
