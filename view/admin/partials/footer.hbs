
<!-- Upload Excel Modal -->

<div
  class="modal fade"
  id="uploadExcelModal"
  tabindex="-1"
>

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
          Upload Dealer Excel
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>

      </div>

      <form
        action="/admin/upload-dealers"
        method="POST"
        enctype="multipart/form-data"
      >

        <div class="modal-body">

          <input
            type="file"
            name="file"
            class="form-control"
            accept=".xlsx,.xls"
            required
          />

        </div>

        <div class="modal-footer">

          <button
            type="submit"
            class="btn btn-login"
          >
            Upload Excel
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

</div>

