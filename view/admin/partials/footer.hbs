{{!-- //for dropdown of action tab in delaer list page --}}
<script>
  function handleDealerAction(action, dealerId) {
    if (!action) return;

    switch(action) {
      case "details":
        window.location.href = `/admin/dealerdetail/${dealerId}`;
        break;

      case "images":
        window.location.href = `/admin/dealer-images/${dealerId}`;
        break;

      case "edit":
        window.location.href = `/admin/edit-dealer/${dealerId}`;
        break;

      default:
        break;
    }
  }
</script>


{{!-- for table paginatipon --}}

<script>
  $(document).ready(function () {
    $('#dataTable').DataTable({
      paging: true,
      searching: true,
      ordering: true,
      pageLength: 10
    });
  });
</script>

{{!-- for admin dashboard graph --}}

  
<script>

const chartLabels = {{{chartLabels}}};

const onboardedData = {{{onboardedData}}};

const uploadedData = {{{uploadedData}}};

const cutoutData = {{{cutoutData}}};

const ctx =
  document.getElementById("dealersChart");

new Chart(ctx, {

  type: "bar",

  data: {

    labels: chartLabels,

    datasets: [

      {
        label: "Onboarded",
        data: onboardedData,
        backgroundColor: "#90caf9",
        borderRadius: 8,
      },

      {
        label: "Uploaded",
        data: uploadedData,
        backgroundColor: "#1a5276",
        borderRadius: 8,
      },

      {
  label: "Cutouts",
  data: cutoutData,
  backgroundColor: "#fbc02d",
  borderRadius: 8,
},
    ],
  },

  options: {

    responsive: true,

    plugins: {

      legend: {
        display: true,
      },
    },

    scales: {

      y: {
        beginAtZero: true,
      },
    },
  },
});
</script>

{{!-- filter button script --}}
<script>

document
  .getElementById("filterBtn")
  .addEventListener("click", () => {

    const state =
      document.getElementById("stateFilter").value;

    const params = new URLSearchParams();

    if (state) {
      params.append("state", state);
    }

    window.location.href =
      `/admin/dashboard?${params.toString()}`;
  });

</script>

</body>
