{{!-- //for dropdown of action tab in delaer list page --}}
<script>
  function handleDealerAction(action, dealerId) {
    if (!action) return;

    switch(action) {
      case "details":
        window.location.href = `/admin/dealerdetail/${dealerId}`;
        break;

      case "images":
        window.location.href = `/admin/dealer-images/${dealerId}`;
        break;

      case "edit":
        window.location.href = `/admin/edit-dealer/${dealerId}`;
        break;

      default:
        break;
    }
  }
</script>


{{!-- for table paginatipon --}}

<script>
  $(document).ready(function () {
    $('#dataTable').DataTable({
      paging: true,
      searching: true,
      ordering: true,
      pageLength: 10
    });
  });
</script>

{{!-- for admin dashboard graph --}}
<script>

  const chartLabels =
    {{{chartLabels}}};

  const chartData =
    {{{chartData}}};

  const ctx =
    document.getElementById(
      "dealersChart"
    );

  new Chart(ctx, {

    type: "bar",

    data: {

      labels: chartLabels,

      datasets: [
        {

          label: "Dealer Data",

          data: chartData,

          backgroundColor: [
            "#90caf9",
            "#1a5276",
            "#fbc02d",
          ],

          borderRadius: 8,

          barThickness: 60,
        },
      ],
    },

    options: {

      responsive: true,

      plugins: {

        legend: {
          display: false,
        },
      },

      scales: {

        y: {
          beginAtZero: true,
        },
      },
    },
  });

</script>
  
</body>
