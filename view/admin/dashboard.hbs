{{> header admin=admin }}
{{> sidebar }}



<!-- MAIN CONTENT -->
<main class="main-content flex-grow-1 p-4">

  
    <!-- Summary Cards -->
<div class="row g-4 mb-4">

    <!-- TOTAL DEALERS -->
    {{!-- <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary-soft">
                <i class="bi bi-people-fill text-primary"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{totalDealers}}
                </div>

                <div class="stat-label">
                    Total Dealers
                </div>
            </div>
        </div>
    </div> --}}

    <!-- ONBOARDED -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon bg-success-soft">
                <i class="bi bi-check-circle-fill text-success"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{onboarded}}
                </div>

                <div class="stat-label">
                    Onboarded
                </div>
            </div>
        </div>
    </div>

    <!-- PICS UPLOADED -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon bg-info-soft">
                <i class="bi bi-image-fill text-info"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{uploadedPics}}
                </div>

                <div class="stat-label">
                    Uploaded
                </div>
            </div>
        </div>
    </div>

    <!-- PENDING -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning-soft">
                <i class="bi bi-clock-fill text-warning"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{cutouts}}
                </div>

                <div class="stat-label">
                    Cutouts
                </div>
            </div>
        </div>
    </div>

</div>
    
  <div class="row mb-4">

  <!-- STATE -->
  <div class="col-md-4">

    <select id="stateFilter" class="form-select">

      <option value="">All States</option>

      {{#each states}}

        <option
          value="{{this}}"
          {{#if (eq ../selectedState this)}}
            selected
          {{/if}}
        >
          {{this}}
        </option>

      {{/each}}

    </select>

  </div>

  <!-- BUTTON -->
  <div class="col-md-2">

    <button
      id="filterBtn"
      class="btn btn-primary w-100"
    >
      Apply Filter
    </button>

  </div>

</div>


    <!-- Bar Chart Card -->
    <div class="chart-card">
        <h5 class="chart-title">Dealers</h5>
        {{!-- <div class="chart-legend d-flex gap-4 mb-4">
            <span class="legend-dot" style="background:#90caf9;"></span><span class="legend-label">Onboarded</span>
            <span class="legend-dot" style="background:#1a5276;"></span><span class="legend-label">Pic Uploaded</span>
            <span class="legend-dot" style="background:#1a5276;"></span><span class="legend-label">Pic Uploaded</span>
        </div> --}}
        <canvas id="dealersChart" height="100"></canvas>
    </div>
    
</main>

{{> footer }}