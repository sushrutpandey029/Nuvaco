{{> header admin=admin }}
{{> sidebar }}



<!-- MAIN CONTENT -->
<main class="main-content flex-grow-1 p-4">
<div class="mb-2 mt-4">
    <h5>
        Total Summary
    </h5>
</div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">

      

        <!-- ONBOARDED -->
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon bg-success-soft">
                    <i class="bi bi-check-circle-fill text-success"></i>
                </div>

                <div>
                    <div class="stat-value">
                        {{onboarded}}
                    </div>

                    <div class="stat-label">
                        Onboarded
                    </div>
                </div>
            </div>
        </div>

        <!-- PICS UPLOADED -->
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon bg-info-soft">
                    <i class="bi bi-image-fill text-info"></i>
                </div>

                <div>
                    <div class="stat-value">
                        {{uploadedPics}}
                    </div>

                    <div class="stat-label">
                        Uploaded
                    </div>
                </div>
            </div>
        </div>

        <!-- PENDING -->
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning-soft">
                    <i class="bi bi-clock-fill text-warning"></i>
                </div>

                <div>
                    <div class="stat-value">
                        {{cutouts}}
                    </div>

                    <div class="stat-label">
                        Cutouts
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row mb-4">

        <!-- STATE -->
        <div class="col-md-4">

            <select id="stateFilter" class="form-select">

                <option value="">All States</option>

                {{#each states}}

                <option value="{{this}}" {{#if (eq ../selectedState this)}} selected {{/if}}>
                    {{this}}
                </option>

                {{/each}}

            </select>

        </div>

        <!-- BUTTON -->
        <div class="col-md-2">

            <button id="filterBtn" class="btn btn-primary w-100">
                Apply Filter
            </button>

        </div>

    </div>

     {{#if selectedState}}

<div class="mb-2 mt-4">
    <h5>
        {{capitalize selectedState}} Summary
    </h5>
</div>

<div class="row g-4 mb-4">

    <!-- STATE ONBOARDED -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">

            <div class="stat-icon bg-success-soft">
                <i class="bi bi-check-circle-fill text-success"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{stateOnboarded}}
                </div>

                <div class="stat-label">
                    State Onboarded
                </div>
            </div>

        </div>
    </div>

    <!-- STATE UPLOADED -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">

            <div class="stat-icon bg-info-soft">
                <i class="bi bi-image-fill text-info"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{stateUploaded}}
                </div>

                <div class="stat-label">
                    State Uploaded
                </div>
            </div>

        </div>
    </div>

    <!-- STATE CUTOUTS -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">

            <div class="stat-icon bg-warning-soft">
                <i class="bi bi-clock-fill text-warning"></i>
            </div>

            <div>
                <div class="stat-value">
                    {{stateCutouts}}
                </div>

                <div class="stat-label">
                    State Cutouts
                </div>
            </div>

        </div>
    </div>

</div>

{{/if}}



    <!-- Bar Chart Card -->
    <div class="chart-card">
        <div
            style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:10px;">
            <h5 class="chart-title">Dealers by State</h5>
            <div style="display:flex; gap:16px; flex-wrap:wrap;">
             
            </div>
        </div>
        <canvas id="dealersChart" height="100"></canvas>
    </div>

</main>

{{> footer }}