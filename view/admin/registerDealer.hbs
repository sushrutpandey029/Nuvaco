{{> header admin=admin }}
{{> sidebar }}

<main class="purple-main" style="align-items:flex-start; padding-top:32px;">
  <div class="pbubble pb1"></div>
  <div class="pbubble pb2"></div>
  <div class="pbubble pb3"></div>
  <div class="pbubble pb4"></div>

  <div style="position:relative; z-index:2; width:100%;">

    <!-- Top Bar -->
    <div class="page-topbar">
      <div class="page-topbar-left">
        <a href="/admin/dealerlist" class="add-btn add-btn-outline" style="text-decoration:none;">
          &#8592; Back to Dealer List
        </a>
      </div>
      <div class="page-topbar-right">
        <button
          type="button"
          class="add-btn add-btn-solid"
          data-bs-toggle="modal"
          data-bs-target="#uploadExcelModal"
        >
          &#8679; Upload Dealer Excel
        </button>
      </div>
    </div>


    <!-- Form Card -->
    <div class="reg-form-card">

      <h5 style="font-weight:700; text-align:center; margin-bottom:24px; color:#1a1a2e; font-size:1.15rem;">
        Register New Dealer
      </h5>

      {{#if error}}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{error}}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      {{/if}}
      {{#if success}}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{success}}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      {{/if}}

      <form id="AdminProfile" action="/admin/registration-delars" method="POST">
        <div class="row g-3">


          <!-- ── Dealer Info ── -->
          <div class="col-12">
            <p style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0;">
              Dealer Information
            </p>
            <hr style="border-color:#ebebf5; margin-top:8px;">
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Dealer Code <span style="color:#e53935;">*</span></label>
            <input name="dealer_code" class="form-control reg-input" placeholder="e.g. 1041102073" required />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Shop Name <span style="color:#e53935;">*</span></label>
            <input name="shop_name" class="form-control reg-input" placeholder="e.g. Kirti Enterprises" required />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Dealer Person Name <span style="color:#e53935;">*</span></label>
            <input name="dealer_person" class="form-control reg-input" placeholder="e.g. Rajiv Kumar" required />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Mobile Number <span style="color:#e53935;">*</span></label>
            <input
              name="dealer_mobile_number"
              class="form-control reg-input"
              placeholder="10-digit mobile number"
              maxlength="10" minlength="10"
              pattern="[0-9]{10}" inputmode="numeric"
              required
            />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">State <span style="color:#e53935;">*</span></label>
            <select name="state" class="form-select reg-input" required>
              <option value="">Select State</option>
              {{#each states}}
                <option value="{{this}}">{{this}}</option>
              {{/each}}
            </select>
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">District <span style="color:#e53935;">*</span></label>
            <input name="district" class="form-control reg-input" placeholder="e.g. Patna" required />
          </div>

          <div class="col-12">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Address <span style="color:#e53935;">*</span></label>
            <input name="address" class="form-control reg-input" placeholder="Full address" required />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Pincode <span style="color:#e53935;">*</span></label>
            <input name="pincode" class="form-control reg-input" placeholder="e.g. 800001" required />
          </div>

          <div class="col-12 col-md-6">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Club Millennium <span style="color:#e53935;">*</span></label>
            <input name="club_millennium" class="form-control reg-input" placeholder="YES / NO" required />
          </div>


          <!-- ── Sales SPOC ── -->
          <div class="col-12" style="margin-top:8px;">
            <p style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0;">
              Sales SPOC
            </p>
            <hr style="border-color:#ebebf5; margin-top:8px;">
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Name</label>
            <input name="sales_spoc[name]" class="form-control reg-input" placeholder="Full name" />
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Email</label>
            <input name="sales_spoc[email]" class="form-control reg-input" placeholder="email@nuvoco.com" type="email" />
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Contact Number</label>
            <input
              name="sales_spoc[contact_number]"
              class="form-control reg-input"
              placeholder="10-digit number"
              maxlength="10" minlength="10"
              pattern="[0-9]{10}" inputmode="numeric"
            />
          </div>


          <!-- ── Trade Marketing SPOC ── -->
          <div class="col-12" style="margin-top:8px;">
            <p style="font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0;">
              Trade Marketing SPOC
            </p>
            <hr style="border-color:#ebebf5; margin-top:8px;">
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Name</label>
            <input name="trade_marketing_spoc[name]" class="form-control reg-input" placeholder="Full name" />
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Email</label>
            <input name="trade_marketing_spoc[email]" class="form-control reg-input" placeholder="email@nuvoco.com" type="email" />
          </div>

          <div class="col-12 col-md-4">
            <label style="font-size:12px; font-weight:600; color:#6b7280; margin-bottom:4px; display:block;">Contact Number</label>
            <input
              name="trade_marketing_spoc[contact_number]"
              class="form-control reg-input"
              placeholder="10-digit number"
              maxlength="10" minlength="10"
              pattern="[0-9]{10}" inputmode="numeric"
            />
          </div>


        </div>

        <!-- Submit -->
        <div class="d-grid mt-4">
          <button type="submit" class="btn btn-login">Register Dealer</button>
        </div>

      </form>
    </div>

  </div>
</main>

{{> footer }}
