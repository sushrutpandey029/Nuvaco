{{> header admin=admin }}
{{> sidebar }}

<main class="purple-main" style="align-items:flex-start; padding-top:32px;">
  <div class="pbubble pb1"></div>
  <div class="pbubble pb2"></div>
  <div class="pbubble pb3"></div>

  <div style="position:relative; z-index:2; width:100%;">

    <!-- Top Bar -->
    <div class="page-topbar">
      <div class="page-topbar-left">
        <h1 class="page-title">State Message List</h1>
        <span class="dealer-count-badge">{{total_records}} records</span>
      </div>
      <div class="page-topbar-right">
        <a href="/admin/add-state-message" class="add-btn add-btn-solid" style="text-decoration:none;">
          &#43; Add Message
        </a>
      </div>
    </div>


    <!-- Table Card -->
    <div class="dl-table-card">
      <div class="table-scroll-wrap">
        <table id="dataTable" class="dealer-table" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th style="width:54px;">#</th>
              <th style="width:140px;">State</th>
              <th>Video</th>
              <th style="width:130px; text-align:center;">Actions</th>
            </tr>
          </thead>

          <tbody>
            {{#if videos.length}}
              {{#each videos}}
              <tr>
                <td class="sno-cell">{{inc @index}}</td>

                <td>
                  <span class="state-badge">{{this.state}}</span>
                </td>

                <td>
                  <video
                    width="160"
                    height="100"
                    controls
                    style="border-radius:8px; display:block;"
                  >
                    <source src="/{{this.video}}" type="video/mp4">
                  </video>
                </td>

                <td style="text-align:center; white-space:nowrap; vertical-align:middle;">
                  <a href="/admin/edit-state-message/{{this.id}}" class="action-btn">
                    &#9998; Edit
                  </a>
                  <form
                    action="/admin/delete-state-message/{{this.id}}"
                    method="POST"
                    style="display:inline;"
                    onsubmit="return confirm('Are you sure you want to delete this message?')"
                  >
                    <button type="submit" class="action-btn del">
                      &#128465; Delete
                    </button>
                  </form>
                </td>
              </tr>
              {{/each}}
            {{else}}
              <tr>
                <td colspan="4" style="text-align:center; color:#aaa; padding:32px; font-size:13px;">
                  No Videos Found
                </td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>

      <!-- Footer / Pagination -->
      {{#if total_pages}}
      <div class="dl-footer-bar">
        <span class="dl-info-text">Page {{current_page}} of {{total_pages}}</span>
        <div class="dl-pagination" id="paginationWrap"></div>
      </div>
      {{/if}}

    </div>

  </div>
</main>

{{> footer }}

{{#if total_pages}}
<script>
(function () {
  var current = {{current_page}};
  var total   = {{total_pages}};
  var wrap    = document.getElementById('paginationWrap');
  if (!wrap) return;

  function btn(label, page, active, disabled) {
    if (disabled) {
      return '<button class="dl-pg-btn disabled" disabled>' + label + '</button>';
    }
    return '<a href="?page=' + page + '" class="dl-pg-btn' + (active ? ' active' : '') + '">' + label + '</a>';
  }

  var html = '';

  // Prev
  html += btn('&laquo;', current - 1, false, current === 1);

  // Page numbers with ellipsis
  var pages = [];
  if (total <= 7) {
    for (var i = 1; i <= total; i++) pages.push(i);
  } else {
    pages.push(1);
    if (current > 3) pages.push('...');
    var s = Math.max(2, current - 1);
    var e = Math.min(total - 1, current + 1);
    for (var j = s; j <= e; j++) pages.push(j);
    if (current < total - 2) pages.push('...');
    pages.push(total);
  }

  pages.forEach(function (p) {
    if (p === '...') {
      html += '<span class="dl-pg-btn" style="cursor:default;border:none;">…</span>';
    } else {
      html += btn(p, p, p === current, false);
    }
  });

  // Next
  html += btn('&raquo;', current + 1, false, current === total);

  wrap.innerHTML = html;
})();
</script>
{{/if}}
