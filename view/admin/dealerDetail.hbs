{{> header admin=admin }}
{{> sidebar }}

<main class="purple-main" style="align-items:flex-start; padding-top:32px;">
  <div class="pbubble pb1"></div>
  <div class="pbubble pb2"></div>
  <div class="pbubble pb3"></div>

  <div style="position:relative; z-index:2; width:100%;">

    <!-- Back Button -->
    <div style="margin-bottom:16px;">
      <a href="/admin/dealerlist" class="add-btn add-btn-outline" style="text-decoration:none;">
        &#8592; Back to Dealer List
      </a>
    </div>


    <!-- Dealer Details -->
    <h2 style="color:#fff; font-size:1.3rem; font-weight:700; margin-bottom:14px;">Dealer Details</h2>

    <div class="dl-table-card" style="margin-bottom:24px;">
      <div style="display:flex; flex-wrap:wrap;">

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; border-right:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Shop Name</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.shop_name}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Dealer Code</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.dealer_code}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; border-right:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Dealer Person</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.dealer_person}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Mobile Number</label>
          <p style="margin:0; font-size:14px; font-weight:600;">
            <a href="tel:{{dealer.mobile_number}}" class="view-link">{{dealer.mobile_number}}</a>
          </p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; border-right:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">State</label>
          <p style="margin:0;"><span class="state-badge">{{dealer.state}}</span></p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">District</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.district}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; border-right:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Pincode</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.pincode}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-bottom:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Address</label>
          <p style="margin:0; font-size:14px; font-weight:600; color:#1a1a2e;">{{dealer.address}}</p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; border-right:1px solid #f0f0f7; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Image Uploaded</label>
          <p style="margin:0;">
            {{#if (eq dealer.isImageUploaded "yes")}}
              <span class="pic-badge-yes">&#10003; Yes</span>
            {{else}}
              <span class="pic-badge-no">&#10007; No</span>
            {{/if}}
          </p>
        </div>

        <div style="flex:0 0 50%; max-width:50%; padding:18px 22px; box-sizing:border-box;">
          <label style="display:block; font-size:11px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px;">Club Millenium</label>
          <p style="margin:0;">
            {{#if (eq dealer.club_millenium "YES")}}
              <span class="pic-badge-yes">&#10003; Yes</span>
            {{else}}
              <span class="pic-badge-no">&#10007; No</span>
            {{/if}}
          </p>
        </div>

      </div>
    </div>


    <!-- Sales SPOC Details -->
    <h2 style="color:#fff; font-size:1.3rem; font-weight:700; margin-bottom:14px;">Sales SPOC Details</h2>

    <div class="dl-table-card" style="margin-bottom:24px;">
      <div class="table-scroll-wrap">
        <table class="dealer-table" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th style="width:60px;">S.No</th>
              <th>Name</th>
              <th>Email</th>
              <th>Contact Number</th>
            </tr>
          </thead>
          <tbody>
            {{#each salesSpoc}}
            <tr>
              <td class="sno-cell">{{inc @index}}</td>
              <td class="dealer-name">{{this.name}}</td>
              <td><a href="mailto:{{this.email}}" class="view-link">{{this.email}}</a></td>
              <td><a href="tel:{{this.contact_number}}" class="view-link">{{this.contact_number}}</a></td>
            </tr>
            {{else}}
            <tr>
              <td colspan="4" style="text-align:center; color:#aaa; padding:20px; font-size:13px;">No Sales SPOC assigned</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>


    <!-- Trade Marketing SPOC Details -->
    <h2 style="color:#fff; font-size:1.3rem; font-weight:700; margin-bottom:14px;">Trade Marketing SPOC Details</h2>

    <div class="dl-table-card" style="margin-bottom:24px;">
      <div class="table-scroll-wrap">
        <table class="dealer-table" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th style="width:60px;">S.No</th>
              <th>Name</th>
              <th>Email</th>
              <th>Contact Number</th>
            </tr>
          </thead>
          <tbody>
            {{#each tradeSpoc}}
            <tr>
              <td class="sno-cell">{{inc @index}}</td>
              <td class="dealer-name">{{this.name}}</td>
              <td><a href="mailto:{{this.email}}" class="view-link">{{this.email}}</a></td>
              <td><a href="tel:{{this.contact_number}}" class="view-link">{{this.contact_number}}</a></td>
            </tr>
            {{else}}
            <tr>
              <td colspan="4" style="text-align:center; color:#aaa; padding:20px; font-size:13px;">No Trade Marketing SPOC assigned</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>


    <!-- Dealer Image (conditional) -->
    {{#if (eq dealer.isImageUploaded "yes")}}
    <h2 style="color:#fff; font-size:1.3rem; font-weight:700; margin-bottom:14px;">Dealer Image</h2>
    <div class="dl-table-card" style="padding:20px 22px; margin-bottom:24px;">
      <a href="/admin/view-image/{{dealer.id}}" class="add-btn add-btn-solid" style="text-decoration:none; display:inline-flex;">
        &#128247; View Uploaded Image
      </a>
    </div>
    {{/if}}

  </div>
</main>

{{> footer }}
