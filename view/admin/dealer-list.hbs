{{> header admin=admin }}
{{> sidebar }}
<main class="purple-main" style="align-items:flex-start; padding-top:32px;">
  <div class="pbubble pb1"></div>
  <div class="pbubble pb2"></div>
  <div class="pbubble pb3"></div>
  <div style="position:relative;z-index:2;width:100%;">
     <!-- Top Header -->
    <div class="page-topbar">

      <div>
  

      <div style="display:flex; gap:12px;">
 <a href="/admin/download-dealer-excel" class="add-btn">
      Download Excel
    </a>

        <a href="/admin/dealerregister" class="add-btn">
          Add Dealer
        </a>
      </div>

    </div>
    <div class="table-scroll-wrap">
      <table id="dataTable" class="dealer-table">
        <thead>
          <tr>
            <th>S.No</th>
             <th>State</th>
            <th>Dealer Name</th>
            <th>Shop Name</th>
           
            <th>Pic Uploaded</th>
            <th>Action</th>
            <th>Image</th>
          </tr>
        </thead>


       <tbody>
  {{#each dealers}}
  <tr>
    <td>{{inc @index}}</td>
     <!-- ✅ state instead of region -->
    <td>{{this.state}}</td>


   
    <td>{{this.dealer_person}}</td>
    <td>{{this.shop_name}}</td>

   
    <td>
      <!-- ✅ correct field -->
      {{#if (eq this.isImageUploaded "yes")}}
        <span style="color:#2e7d32;font-weight:600;">Yes</span>
      {{else}}
        <span style="color:#c62828;font-weight:600;">No</span>
      {{/if}}
    </td>

    <td>
      <a href="dealerdetail/{{this.id}}" class="view-link">View</a>
      <a href="/admin/editdealer/{{this.id}}" class="view-link">
  Edit
</a>

<a
  href="/admin/delete-dealer/{{this.id}}"
  class="view-link"
  onclick="return confirm('Are you sure you want to delete this dealer?')"
>
  Delete
</a>
     {{!-- <a href="dealerdetail/{{this.id}}" class="view-link">Edit</a>

<a href="dealerdetail/{{this.id}}" class="view-link">Delete</a>
      --}}
    </td>
   <td>
  {{#if (eq this.isImageUploaded "yes")}}
    <a href="dealer-image/{{this.id}}" class="view-link">
      View
    </a>
  {{else}}
    -
  {{/if}}
</td>
  </tr>
  {{/each}}
</tbody>


      </table>
    </div>
  </div>
</main>
{{> footer }}