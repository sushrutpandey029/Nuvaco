<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuvoco – Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="assets/css/style.css" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</head>

<body class="login-body">

    <div class="container-fluid h-100">
        <div class="row h-100">

            <!-- Left branding panel -->
            <div class="col-lg-6 login-left d-flex align-items-center justify-content-center">
                <div class="bubble b1"></div>
                <div class="bubble b2"></div>
                <div class="bubble b3"></div>
                <div class="text-center">
                    <div class="logo-ring">
                        <div class="logo-text">
                            <span class="nu">NU</span><span class="v-letter">V</span><span class="oco">OCO</span><sup
                                class="reg">®</sup>
                        </div>
                        <div class="tagline">Shaping a new world</div>
                    </div>
                </div>
            </div>

            <!-- Right login form -->
            <div class="col-lg-6 login-right d-flex align-items-center justify-content-center">
                <div class="bubble br1"></div>
                <div class="bubble br2"></div>
                <div class="login-card">
                    <h2 class="login-title">Log in</h2>
                    <div class="title-underline"></div>

                    <form id="AdminProfile" action="/adminsigin" method="POST">
                        <div class="mb-4">
                            <input type="text" class="form-control login-input" placeholder="Enter Your Admin ID" />
                        </div>
                        <div class="mb-4">
                            <input type="password" class="form-control login-input" placeholder="Enter Your Password" />
                        </div>
                        {{!-- <div class="mb-5">
                            <input type="text" class="form-control login-input" placeholder="Captcha for Security" />
                        </div> --}}
                         <div 
              class="g-recaptcha"
              data-sitekey="6LdZ150sAAAAAPhjw_YeWLo3Q6ipUREs3cHGdCrE"
              data-callback="enableLogin"
            ></div>


                        <div class="d-grid">
                            <button type="submit" class="btn btn-login">Login</button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>